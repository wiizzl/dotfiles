#!/bin/bash

set -euo pipefail

# Set Fish as default shell
chsh -s /usr/bin/fish

# Cleanup
sudo dnf clean all
sudo dnf autoremove -y

# Hostname
{{- $fedora_type := "" -}}
{{- if .is_laptop -}}
  {{- $fedora_type = "laptop" -}}
{{- else -}}
  {{- $fedora_type = "desktop" -}}
{{- end -}}
sudo hostnamectl set-hostname "fedora-{{ $fedora_type }}"
