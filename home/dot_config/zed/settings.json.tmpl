{
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },

  "icon_theme": "Catppuccin Mocha",

  "base_keymap": "VSCode",

  "buffer_font_family": "{{ .mono_font }}",
  "buffer_font_size": 15,
  "ui_font_size": 15,

  "image_viewer": {
    "unit": "decimal",
  },

  "colorize_brackets": true,

  "middle_click_paste": false,

  "minimap": {
    "show": "always",
    "display_in": "all_editors",
    "max_width_columns": 65,
  },

  "diagnostics": {
    "button": true,
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 4,
      "min_column": 0,
      "max_severity": null,
    },
  },

  "edit_predictions": {
    "provider": "copilot",
    "copilot": {
      "enable_next_edit_suggestions": false,
    },
  },

  "agent": {
    "dock": "left",
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1",
      "enable_thinking": true,
    },
  },

  "git_panel": {
    "dock": "right",
  },
  "project_panel": {
    "dock": "right",
    "auto_fold_dirs": false,
  },

  "max_tabs": 6,
  "autosave": "on_focus_change",

  "lsp": {
    "tailwindcss-language-server": {
      "settings": {
        "classFunctions": ["cva", "cx"],
      },
    },
  },

  "tab_size": 2,

  "auto_install_extensions": {
    "html": true,
    "toml": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "java": true,
    "dockerfile": true,
    "docker-compose": true,
    "php": true,
    "sql": true,
    "xml": true,
    "csharp": true,
    "zig": true,
    "astro": true,
    "prisma": true,
    "discord-presence": true,
  },

  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
}
