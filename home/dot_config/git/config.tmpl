[user]
	email = "{{ .git_email }}"
	name = "{{ .git_name }}"
	signingkey = "{{ (bitwarden "item" "git-sign").sshKey.publicKey }}"

[gpg]
    format = "ssh"

[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers

[commit]
	gpgsign = true

[tag]
	gpgSign = true

[init]
	defaultBranch = "main"

[pull]
	rebase = true

[url "git@github.com:"]
	insteadOf = gh:

[url "git@gitlab.com:"]
	insteadOf = gl:

[url "git@github.com:{{ .github_username }}/"]
	insteadOf = me: