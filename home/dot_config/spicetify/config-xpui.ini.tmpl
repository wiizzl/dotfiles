[Preprocesses]
disable_ui_logging = 1
remove_rtl_rule = 1
expose_apis = 1
disable_sentry = 1

[AdditionalOptions]
extensions = {{- $first := true -}}{{- range $name, $_ := .extensions.spicetify }}{{- if not $first }}|{{ end }}{{ $name }}.js{{- $first = false }}{{- end }}
custom_apps =
sidebar_config = 0
home_config = 1
experimental_features = 1

[Patch]

[Setting]
{{- if eq .chezmoi.os "linux" }}
spotify_path = /var/lib/flatpak/app/com.spotify.Client/x86_64/stable/active/files/extra/share/spotify
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
spotify_path = /Applications/Spotify.app/Contents/Resources
{{- end }}
{{- if eq .chezmoi.os "linux" }}
prefs_path = {{ .chezmoi.homeDir }}/.var/app/com.spotify.Client/config/spotify/prefs
{{- end }}
{{- if eq .chezmoi.os "darwin" }}
prefs_path =
{{- end }}
inject_css = 1
check_spicetify_update = 1
current_theme = catppuccin
color_scheme = mocha
inject_theme_js = 1
replace_colors = 1
overwrite_assets = 1
spotify_launch_flags =
always_enable_devtools = 0

[Backup]
version =
with =